data:text/html,<!DOCTYPE html><html><head><style>body,html{margin:0;padding:0;width:100%;height:100%;overflow:hidden;background:#000;font-family:Arial}iframe{width:100%;height:100%;border:none;position:absolute;top:0;left:0;z-index:1}.timer-bar{position:fixed;top:24%;left:0;width:160px;height:32px;background:#000!important;padding:0 10px;box-sizing:border-box;display:flex;justify-content:flex-end;align-items:center;z-index:99999999!important;cursor:pointer}.time-text{font-weight:900;line-height:1;user-select:none;display:flex;align-items:baseline;font-variant-numeric:tabular-nums;background:linear-gradient(to bottom,#fff 15%,#7a7a7a 90%);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}.main-num{font-size:26px}.sub-num{font-size:18px;margin-left:1px}</style></head><body><iframe id="g" src="https://ss.randomkzn.com"></iframe><div class="timer-bar" id="b"><div class="time-text"><span id="m" class="main-num">0</span><span id="s" class="sub-num">.00</span></div></div><script>let st=0,et=0,iv=null,ir=false;const m=document.getElementById('m'),s=document.getElementById('s'),b=document.getElementById('b'),g=document.getElementById('g');function sp(){if(!ir){st=Date.now()-et;iv=setInterval(up,10);ir=true}else{clearInterval(iv);et=Date.now()-st;ir=false}}function rs(){clearInterval(iv);st=0;et=0;ir=false;m.textContent='0';s.textContent='.00'}function up(){et=Date.now()-st;let ms=et;let min=Math.floor(ms/60000);ms%=60000;let sec=Math.floor(ms/1000);let msec=Math.floor((ms%1000)/10);m.textContent=min>0?min+':'+String(sec).padStart(2,'0'):sec;s.textContent='.'+String(msec).padStart(2,'0')}window.addEventListener('keydown',e=>{const k=e.key.toLowerCase();if(k==='t'){e.preventDefault();sp()}if(k==='y'){e.preventDefault();rs()}},true);b.addEventListener('click',sp);</script></body></html>
