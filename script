javascript:(function(){if(document.querySelector('.custom-timer-bar'))return;const s=document.createElement('style');s.innerHTML=`.custom-timer-bar{position:fixed;top:24%;left:0;width:160px;height:32px;background:#000000!important;padding:0 10px;box-sizing:border-box;display:flex;justify-content:flex-end;align-items:center;z-index:99999999!important;cursor:pointer;font-family:Arial,sans-serif;}.custom-time-text{font-weight:900;line-height:1;user-select:none;display:flex;align-items:baseline;font-variant-numeric:tabular-nums;background:linear-gradient(to bottom,#ffffff 15%,#7a7a7a 90%);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;}.custom-main-num{font-size:26px;}.custom-sub-num{font-size:18px;margin-left:1px;}`;document.head.appendChild(s);const b=document.createElement('div');b.className='custom-timer-bar';const t=document.createElement('div');t.className='custom-time-text';const m=document.createElement('span');m.className='custom-main-num';m.textContent='0';const d=document.createElement('span');d.className='custom-sub-num';d.textContent='.00';t.appendChild(m);t.appendChild(d);b.appendChild(t);document.body.appendChild(b);let st=0,et=0,iv=null,ir=false;function sp(){if(!ir){st=Date.now()-et;iv=setInterval(up,10);ir=true;}else{clearInterval(iv);et=Date.now()-st;ir=false;}}function rs(){clearInterval(iv);st=0;et=0;ir=false;m.textContent='0';d.textContent='.00';}function up(){et=Date.now()-st;let ms=et;let min=Math.floor(ms/60000);ms%=60000;let sec=Math.floor(ms/1000);let msec=Math.floor((ms%1000)/10);m.textContent=min>0?`${min}:${String(sec).padStart(2,'0')}`:sec;d.textContent=`.${String(msec).padStart(2,'0')}`;}window.addEventListener('keydown',e=>{const k=e.key.toLowerCase();if(document.activeElement.tagName==='INPUT'||document.activeElement.tagName==='TEXTAREA')return;if(k==='t')sp();if(k==='y')rs();},true);b.addEventListener('click',sp);})();
