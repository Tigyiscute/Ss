javascript:(function(){if(document.getElementById('sr-timer-widget')){alert('Timer already loaded!');return;}const el=document.createElement('div');el.id='sr-timer-widget';el.style= 'position:fixed;bottom:20px;right:20px;width:280px;background:rgba(17,17,17,0.95);border:2px solid #333;border-radius:6px;padding:15px;color:#fff;box-shadow:0 10px 30px rgba(0,0,0,0.8);user-select:none;z-index:999999;font-family:sans-serif;';el.innerHTML=`<div style="font-size:11px;text-transform:uppercase;letter-spacing:1px;color:#888;margin-bottom:5px;border-bottom:1px solid #333;padding-bottom:3px;">Any% New York Speedrun</div><div id="sr-display" style="font-family:monospace;font-size:38px;font-weight:bold;text-align:right;color:#4ef21d;text-shadow:0 0 10px rgba(78,242,29,0.3);letter-spacing:-1px;">00:00:00<span style="font-size:24px;color:#a3f78c;">.00</span></div><div style="display:flex;gap:5px;margin-top:10px;"><button id="sr-start" style="flex:1;background:#222;border:1px solid #28a745;color:#fff;padding:6px 0;font-size:11px;font-weight:bold;text-transform:uppercase;cursor:pointer;border-radius:3px;">Start</button><button id="sr-reset" style="flex:1;background:#222;border:1px solid #dc3545;color:#fff;padding:6px 0;font-size:11px;font-weight:bold;text-transform:uppercase;cursor:pointer;border-radius:3px;">Reset</button></div><div style="font-size:9px;color:#555;text-align:center;margin-top:8px;text-transform:uppercase;">Space: Start/Pause | R: Reset</div>`;document.body.appendChild(el);let startTime=0,elapsedTime=0,timerInterval=null,isRunning=false;const disp=document.getElementById('sr-display'),startBtn=document.getElementById('sr-start'),resetBtn=document.getElementById('sr-reset');function startPause(){if(!isRunning){startTime=Date.now()-elapsedTime;timerInterval=setInterval(updateTime,10);isRunning=true;disp.style.color='#4ef21d';startBtn.textContent='Pause';}else{clearInterval(timerInterval);elapsedTime=Date.now()-startTime;isRunning=false;disp.style.color='#aaa';startBtn.textContent='Resume';}}function reset(){clearInterval(timerInterval);startTime=0;elapsedTime=0;isRunning=false;disp.style.color='#aaa';disp.innerHTML='00:00:00<span style="font-size:24px;color:#888;">.00</span>';startBtn.textContent='Start';}function updateTime(){elapsedTime=Date.now()-startTime;let ms=elapsedTime;let h=Math.floor(ms/3600000);ms%=3600000;let m=Math.floor(ms/60000);ms%=60000;let s=Math.floor(ms/1000);let displayMs=Math.floor((ms%1000)/10);disp.innerHTML=`${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}<span style="font-size:24px;color:#a3f78c;">.${String(displayMs).padStart(2,'0')}</span>`;}startBtn.addEventListener('click',startPause);resetBtn.addEventListener('click',reset);window.addEventListener('keydown',(e)=>{if(e.code==='Space'){e.preventDefault();startPause();}if(e.code==='KeyR'){reset();}});})();
