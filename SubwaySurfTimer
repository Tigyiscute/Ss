<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New York Speedrun Dashboard</title>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: #000;
            font-family: Arial, sans-serif;
        }

        /* Container for the loaded website content */
        #site-container {
            width: 100%;
            height: 100%;
            border: none;
            overflow: auto;
        }

        /* Speedrun Timer Widget Overlay */
        .timer-widget {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 280px;
            background: rgba(17, 17, 17, 0.92);
            backdrop-filter: blur(4px);
            border: 2px solid #333;
            border-radius: 6px;
            padding: 15px;
            color: #fff;
            box-shadow: 0 10px 30px rgba(0,0,0,0.7);
            user-select: none;
            z-index: 999999;
        }

        .timer-title {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #888;
            margin-bottom: 5px;
            border-bottom: 1px solid #333;
            padding-bottom: 3px;
        }

        .time-display {
            font-family: monospace;
            font-size: 38px;
            font-weight: bold;
            text-align: right;
            color: #4ef21d;
            text-shadow: 0 0 10px rgba(78, 242, 29, 0.3);
            letter-spacing: -1px;
        }

        .time-display .ms {
            font-size: 24px;
            color: #a3f78c;
        }

        .time-display.paused {
            color: #aaa;
            text-shadow: none;
        }
        .time-display.paused .ms {
            color: #888;
        }

        .timer-controls {
            display: flex;
            gap: 5px;
            margin-top: 10px;
        }

        .btn {
            flex: 1;
            background: #222;
            border: 1px solid #444;
            color: #fff;
            padding: 6px 0;
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
            cursor: pointer;
            border-radius: 3px;
        }

        .btn:hover { background: #333; }
        .btn-start { border-color: #28a745; }
        .btn-reset { border-color: #dc3545; }

        .hotkeys-hint {
            font-size: 9px;
            color: #555;
            text-align: center;
            margin-top: 8px;
            text-transform: uppercase;
        }

        /* Loading Screen overlay */
        #loader {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: #111; color: #4ef21d;
            display: flex; justify-content: center; align-items: center;
            font-size: 20px; font-weight: bold; z-index: 1000000;
            font-family: monospace;
        }
    </style>
</head>
<body>

    <div id="loader">Bypassing Frame Restrictions & Loading Layout...</div>

    <div id="site-container"></div>

    <div class="timer-widget">
        <div class="timer-title">Any% New York Speedrun</div>
        <div class="time-display paused" id="display">00:00:00<span class="ms">.00</span></div>
        <div class="timer-controls">
            <button class="btn btn-start" id="startPauseBtn">Start</button>
            <button class="btn btn-reset" id="resetBtn">Reset</button>
        </div>
        <div class="hotkeys-hint">T: Start/Pause | Y: Reset</div>
    </div>

    <script>
        // 1. Bypass Security Restrictions via a Secure CORS Proxy Fetch
        const targetUrl = "https://therealoness.squareweb.app/newyork";
        const proxyUrl = "https://api.allorigins.win/get?url=" + encodeURIComponent(targetUrl);

        fetch(proxyUrl)
            .then(response => {
                if (response.ok) return response.json();
                throw new Error('Network response failure.');
            })
            .then(data => {
                const container = document.getElementById('site-container');
                container.innerHTML = data.contents;
                document.getElementById('loader').style.display = 'none';
            })
            .catch(err => {
                document.getElementById('loader').innerText = "Failed to fetch source page. Try reloading.";
                console.error(err);
            });

        // 2. High Precision Speedrun Timer Logic
        let startTime = 0;
        let elapsedTime = 0;
        let timerInterval = null;
        let isRunning = false;

        const displayEl = document.getElementById('display');
        const startPauseBtn = document.getElementById('startPauseBtn');
        const resetBtn = document.getElementById('resetBtn');

        function startPause() {
            if (!isRunning) {
                startTime = Date.now() - elapsedTime;
                timerInterval = setInterval(updateTime, 10);
                isRunning = true;
                displayEl.classList.remove('paused');
                startPauseBtn.textContent = 'Pause';
            } else {
                clearInterval(timerInterval);
                elapsedTime = Date.now() - startTime;
                isRunning = false;
                displayEl.classList.add('paused');
                startPauseBtn.textContent = 'Resume';
            }
        }

        function reset() {
            clearInterval(timerInterval);
            startTime = 0;
            elapsedTime = 0;
            isRunning = false;
            displayEl.classList.add('paused');
            displayEl.innerHTML = '00:00:00<span class="ms">.00</span>';
            startPauseBtn.textContent = 'Start';
        }

        function updateTime() {
            elapsedTime = Date.now() - startTime;
            let ms = elapsedTime;
            let h = Math.floor(ms / 3600000); ms %= 3600000;
            let m = Math.floor(ms / 60000); ms %= 60000;
            let s = Math.floor(ms / 1000);
            let displayMs = Math.floor((ms % 1000) / 10);

            displayEl.innerHTML = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}<span class="ms">.${String(displayMs).padStart(2,'0')}</span>`;
        }

        startPauseBtn.addEventListener('click', startPause);
        resetBtn.addEventListener('click', reset);

        // Custom Keybind Listeners (T and Y)
        window.addEventListener('keydown', (e) => {
            // "T" key triggers Start/Pause
            if (e.code === 'KeyT') {
                startPause();
            }
            // "Y" key triggers Reset
            if (e.code === 'KeyY') {
                reset();
            }
        });
    </script>
</body>
</html>
