<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Speedrun Dashboard</title>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: #000;
            font-family: Arial, sans-serif;
        }

        /* Fullscreen Web View Container */
        .content-frame {
            width: 100%;
            height: 100%;
            border: none;
        }

        /* Exact layout style from your image */
        .timer-widget {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: #000000; /* Solid black container box */
            padding: 10px 25px;
            border-radius: 4px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
            user-select: none;
            z-index: 999999;
            text-align: center;
        }

        /* Crisp white timer text with a heavy, sharp dark gray drop shadow */
        .time-display {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            font-size: 56px;
            font-weight: 700;
            color: #ffffff; /* Solid White */
            
            /* The specific shading block matching the depth from your reference photo */
            text-shadow: 2px 2px 0px #222222, 
                         3px 3px 0px #1a1a1a; 
                         
            letter-spacing: -2px;
            line-height: 1;
        }

        /* Keeps the digits perfectly aligned as they change */
        .time-display span {
            font-variant-numeric: tabular-nums;
        }

        /* Functional control buttons */
        .timer-controls {
            display: flex;
            gap: 5px;
            margin-top: 12px;
        }

        .btn {
            flex: 1;
            background: #111;
            border: 1px solid #333;
            color: #777;
            padding: 4px 0;
            font-size: 10px;
            font-weight: bold;
            text-transform: uppercase;
            cursor: pointer;
            border-radius: 3px;
        }
        .btn:hover { color: #fff; background: #222; }

        .hotkeys-hint {
            font-size: 9px;
            color: #444;
            margin-top: 6px;
            text-transform: uppercase;
            font-weight: bold;
            letter-spacing: 0.5px;
        }
    </style>
</head>
<body>

    <iframe class="content-frame" src="https://therealoness.squareweb.app/newyork"></iframe>

    <div class="timer-widget">
        <div class="time-display" id="display">1:00.00</div>
        
        <div class="timer-controls">
            <button class="btn" id="startPauseBtn">Start (T)</button>
            <button class="btn" id="resetBtn">Reset (Y)</button>
        </div>
        <div class="hotkeys-hint">T to start • Y to reset</div>
    </div>

    <script>
        let startTime = 0;
        let elapsedTime = 0;
        let timerInterval = null;
        let isRunning = false;

        const displayEl = document.getElementById('display');
        const startPauseBtn = document.getElementById('startPauseBtn');
        const resetBtn = document.getElementById('resetBtn');

        function startPause() {
            if (!isRunning) {
                startTime = Date.now() - elapsedTime;
                timerInterval = setInterval(updateTime, 10);
                isRunning = true;
                startPauseBtn.textContent = 'Pause (T)';
            } else {
                clearInterval(timerInterval);
                elapsedTime = Date.now() - startTime;
                isRunning = false;
                startPauseBtn.textContent = 'Resume (T)';
            }
        }

        function reset() {
            clearInterval(timerInterval);
            startTime = 0;
            elapsedTime = 0;
            isRunning = false;
            displayEl.textContent = '0:00.00';
            startPauseBtn.textContent = 'Start (T)';
        }

        function updateTime() {
            elapsedTime = Date.now() - startTime;
            let totalMs = elapsedTime;

            let hours = Math.floor(totalMs / 3600000);
            totalMs %= 3600000;
            
            let minutes = Math.floor(totalMs / 60000);
            totalMs %= 60000;
            
            let seconds = Math.floor(totalMs / 1000);
            let milliseconds = Math.floor((totalMs % 1000) / 10);

            let sStr = String(seconds).padStart(2, '0');
            let msStr = String(milliseconds).padStart(2, '0');

            if (hours > 0) {
                let mStr = String(minutes).padStart(2, '0');
                displayEl.textContent = `${hours}:${mStr}:${sStr}.${msStr}`;
            } else {
                displayEl.textContent = `${minutes}:${sStr}.${msStr}`;
            }
        }

        startPauseBtn.addEventListener('click', startPause);
        resetBtn.addEventListener('click', reset);

        // Bind Configurations
        window.addEventListener('keydown', (e) => {
            if (e.code === 'KeyT') {
                startPause();
            }
            if (e.code === 'KeyY') {
                reset();
            }
        });
    </script>
</body>
</html>
